{
  "headers": [
    {
      "source": "/(.*)\\.(js|css|png|jpg|jpeg|webp|svg|ico|woff2?)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/pompe-a-chaleur/:slug", "destination": "/" },
    { "source": "/pompe-a-chaleur/:slug/", "destination": "/" },
    { "source": "/((?!api/|static/|.*\\..*).*)", "destination": "/" }
  ]
}
